execute pathogen#infect()
syntax on
filetype plugin indent on
" Indentation
set sw=2
set ts=2
set autoindent
set expandtab
"set smartindent
"set cindent
" default: set
"set cinoptions=>1s,:0=,1s,g0,c3
":set foldmethod=indent
" show tabs and trailing spaces
set list
set listchars=tab:>∙,trail:∙

let g:airline_powerline_fonts = 1
